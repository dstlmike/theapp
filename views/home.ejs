<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* Mobile styles (default) */
        body {
            font-family: sans-serif;
            padding: 20px;
            background: #f0f0f0;
width: 100%;
        }
        .container {
            background: white;
            padding: 20px;
            border-radius: 8px;
width: 100%;
        }

        /* Desktop styles (screens wider than 768px) */
        @media (min-width: 768px) {
            body {
                background: #d1d1d1;
                display: flex;
                justify-content: center;
            }
            .container {
                width: 100%; /* Mimics a fixed window feel */
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Responsive Page</h1>
        <p>This layout adapts as you resize your browser window.</p>
  <hr>
<form action="/home" method="POST" enctype="multipart/form-data">
            
              <label for="image">Upload Image</label>
              <input type="file" id="image" name="image" accept="image/*" required />
                <label for="description">Description</label>
                <input type="text" id="description" name="description" required />

                <id="address" name="address" />

            
            
<button type="submit" onclick="window.Android.showToast('Button clicked!')">Click Me in HTML</button>
                
            
        </form>
</hr>

<% if (items.length > 0) { %>
            <% items.forEach(item => { %>
             
                    <img src="data:<%= item.img.contentType %>;base64,<%= item.img.data.toString('base64') %>" />
<p style="text-align:center;"><%= item.img.description %></p>
                
            <% }); %>
        <% } %>
</div>
</body>
</html>
