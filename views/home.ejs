<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width;">
    <style>
        /* Mobile styles (default) */
        body {
            font-family: sans-serif;
            padding: 20px;
            background: #f0f0f0;
margin-left: auto;
margin-right: auto;
 justify-content: center;
align-items: center;
        }
img {
display: block;
  margin: auto;
  width: 40%;
}
        .container {
            background: white;
            padding: 20px;
            border-radius: 8px;
margin-left: auto;
margin-right: auto;
 justify-content: center;
align-items: center;
        }


        /* Desktop styles (screens wider than 768px) */
        @media (min-width: 768px) {
            body {
                background: #d1d1d1;
                display: inline-block;
                justify-content: center;
align-items: center;
width:90%;
margin-left: auto;
margin-right: auto;
            }
img {
display: block;
  margin: auto;
  width: 40%;
}
            .container {
                width: 100%; /* Mimics a fixed window feel */
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
margin-left: auto;
margin-right: auto;
 justify-content: center;
align-items: center;
            }
        }
    </style>
</head>
<body>
 <div class="container">
        <h1 style="text-align:center">Field Report</h1>
        <p>Date Submited: March 3, 2026</p>
<p>Address: <br> 2362 Wyecroft Road Unit 2<br>Oakvile, Ontario<br>L6L 6M1</p>

  <hr>
<form action="/home" method="POST" enctype="multipart/form-data">
            
              <label for="image">Upload Image</label>
              <input type="file" id="image" name="image" accept="image/*" required />
                <label for="description"><br>Description: </label>
                <input type="text" id="description" name="description" required />

                <id="address" name="address" />

            <p></p>
            
<button type="submit" onclick="window.Android.showToast('Button clicked!')">Submit</button>
                
            <p><br></p>
        </form>
</hr>
</div>
<div class="container">
<% if (items.length > 0) { %>
            <% items.forEach(item => { %>
             
                    <img src="data:<%= item.img.contentType %>;base64,<%= item.img.data.toString('base64') %>"/>
<p style="text-align:center;"><%= item.img.description %></p>
                
            <% }); %>
        <% } %>
</div>
</body>
</html>
